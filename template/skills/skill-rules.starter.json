{
  "version": "3.0",
  "description": "Skill activation triggers — edit this for your project",

  "config": {
    "baseBranch": "main",
    "progressiveDisclosure": true,
    "defaultPriority": "high",
    "evolutionPatterns": []
  },

  "domains": {
    "example": {
      "path": "example/SKILL.md",
      "description": "Example domain — replace with your own",
      "promptTriggers": {
        "keywords": ["example"]
      },
      "fileTriggers": {
        "pathPatterns": ["src/**"]
      }
    }
  }
}
